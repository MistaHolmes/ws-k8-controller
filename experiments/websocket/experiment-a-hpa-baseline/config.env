# experiments/websocket/experiment-a-hpa-baseline/config.env

# --------------------------------------------------
# Cluster Configuration
# --------------------------------------------------
CLUSTER_NAME=stateful-exp
CLUSTER_TYPE=kind-multi-node

# --------------------------------------------------
# Load Parameters
# --------------------------------------------------
LOAD_CLIENTS=800
LOAD_DURATION_SECONDS=300

# --------------------------------------------------
# Autoscaler Configuration
# --------------------------------------------------
MIN_REPLICAS=2
MAX_REPLICAS=10
CPU_TARGET_PERCENT=60
SCALE_DOWN_STABILIZATION_SECONDS=300

# --------------------------------------------------
# Monitoring
# --------------------------------------------------
METRICS_SERVER_ENABLED=true
PROMETHEUS_ENABLED=true
SCRAPE_INTERVAL_SECONDS=15

# --------------------------------------------------
# Logging
# --------------------------------------------------
SAMPLING_INTERVAL_SECONDS=5

# --------------------------------------------------
# Result Paths
# --------------------------------------------------
RAW_RESULTS_PATH=results/raw/websocket/experiment-a-hpa
PROCESSED_RESULTS_PATH=results/processed/websocket/experiment-a-hpa